NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta
ASAAS_API_KEY=sua-chave-secreta-do-asaas
ASAAS_WEBHOOK_TOKEN=um-token-forte-configurado-no-webhook-do-asaas
APP_ORIGIN=https://sistema-impressao.vercel.app

# Agente local de impressao
PRINT_AGENT_SIMULATE=true
PRINT_AGENT_POLL_MS=15000
PRINT_AGENT_PRINTER_NAME=Microsoft Print to PDF
PRINT_AGENT_DOWNLOAD_DIR=print-agent-downloads

# Opcional. Se ficar vazio, o app escolhe producao quando a chave indicar prod,
# e sandbox nos demais casos.
# ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
# ASAAS_API_BASE_URL=https://api.asaas.com/v3
